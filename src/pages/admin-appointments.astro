---
import Layout from '../layouts/Layout.astro';

export const prerender = false;

// Access Cloudflare environment strictly as requested
const runtime = Astro.locals.runtime;
const env = runtime?.env;
const DB = env?.DB;

let appointments = [];
let error = null;

// Simple password protection
const ADMIN_PASSWORD = env?.ADMIN_PASSWORD || "admin123"; 
const url = new URL(Astro.request.url);
const pass = url.searchParams.get('pass');
const authorized = pass === ADMIN_PASSWORD;

if (authorized) {
    if (!DB) {
        error = "Database binding 'DB' not found.";
    } else {
        try {
            // Using the requested SQL statement structure
            const { results } = await DB.prepare('SELECT * FROM appointments ORDER BY created_at DESC').all();
            appointments = results;
        } catch (e) {
            error = e.message;
        }
    }
}
---

<Layout title="Admin Appointments">
    <main class="pt-32 pb-20 px-4 md:px-8 max-w-7xl mx-auto">
        {!authorized ? (
            <div class="max-w-md mx-auto bg-surface-container-low p-8 rounded-xl shadow-sm text-center border border-outline-variant/20">
                <div class="mb-6 inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary/10 text-primary">
                    <span class="material-symbols-outlined text-3xl">lock</span>
                </div>
                <h1 class="text-2xl font-bold mb-2 text-on-surface">Πρόσβαση Διαχειριστή</h1>
                <p class="mb-6 text-on-surface-variant text-sm">Παρακαλώ εισάγετε τον κωδικό πρόσβασης για να δείτε τα ραντεβού.</p>
                
                <form method="GET" class="space-y-4">
                    <div class="relative">
                        <input 
                            type="password" 
                            name="pass" 
                            required
                            placeholder="Κωδικός πρόσβασης" 
                            class="w-full bg-surface-container-high border-none rounded-lg p-4 focus:ring-2 focus:ring-primary focus:bg-surface-container-highest transition-all text-on-surface"
                        />
                    </div>
                    <button type="submit" class="w-full bg-primary text-on-primary py-4 rounded-xl font-bold hover:shadow-lg transition-all active:scale-95">
                        Είσοδος
                    </button>
                </form>
            </div>
        ) : (
            <div class="animate-in fade-in duration-500">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10">
                    <div>
                        <h1 class="text-3xl font-bold text-primary tracking-tight">Λίστα Ραντεβού</h1>
                        <p class="text-on-surface-variant mt-1 text-sm">Διαχείριση των εισερχόμενων αιτημάτων για συνεδρίες.</p>
                    </div>
                    <a href="/admin-appointments" class="px-4 py-2 text-sm font-medium text-outline hover:text-primary border border-outline-variant/50 rounded-lg hover:border-primary transition-all flex items-center gap-2 bg-surface-container-lowest">
                        <span class="material-symbols-outlined text-sm">logout</span>
                        Έξοδος
                    </a>
                </div>

                {error && (
                    <div class="bg-error-container text-on-error-container p-4 rounded-xl mb-8 flex items-center gap-3 border border-error/20">
                        <span class="material-symbols-outlined">error</span>
                        <p class="font-medium">{error}</p>
                    </div>
                )}

                <div class="overflow-x-auto bg-surface-container-low rounded-2xl shadow-sm border border-outline-variant/10">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-surface-container-high/50 border-b border-outline-variant/30">
                                <th class="p-5 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Όνομα</th>
                                <th class="p-5 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Επικοινωνία</th>
                                <th class="p-5 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Σκοπός</th>
                                <th class="p-5 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Ημερομηνία & Ώρα</th>
                                <th class="p-5 text-xs font-bold text-on-surface-variant uppercase tracking-wider text-center">Κατάσταση</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/10">
                            {appointments.length === 0 && !error && (
                                <tr>
                                    <td colspan="5" class="p-10 text-center text-on-surface-variant opacity-60">
                                        Δεν βρέθηκαν ραντεβού στον πίνακα.
                                    </td>
                                </tr>
                            )}
                            {appointments.map((app) => (
                                <tr class="hover:bg-primary/5 transition-colors group">
                                    <td class="p-5">
                                        <div class="font-bold text-on-surface group-hover:text-primary transition-colors">{app.fullname}</div>
                                        <div class="text-xs text-outline mt-0.5">ID: {app.id}</div>
                                    </td>
                                    <td class="p-5">
                                        <a href={`tel:${app.phone}`} class="text-on-surface-variant hover:text-primary hover:underline flex items-center gap-2">
                                            <span class="material-symbols-outlined text-base">phone</span>
                                            {app.phone}
                                        </a>
                                    </td>
                                    <td class="p-5 text-on-surface-variant font-medium">{app.purpose}</td>
                                    <td class="p-5">
                                        <div class="flex flex-col">
                                            <span class="font-bold text-on-surface">{app.appointment_date}</span>
                                            <span class="text-xs font-medium text-secondary flex items-center gap-1">
                                                <span class="material-symbols-outlined text-xs">schedule</span>
                                                {app.appointment_time}
                                            </span>
                                        </div>
                                    </td>
                                    <td class="p-5">
                                        <div class="flex justify-center">
                                            <span class={`px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest ${
                                                app.status === 'pending' ? 'bg-secondary-container text-on-secondary-container' : 
                                                app.status === 'confirmed' ? 'bg-primary/20 text-primary' : 'bg-outline-variant/20 text-outline'
                                            }`}>
                                                {app.status === 'pending' ? 'ΣΕ ΕΚΚΡΕΜΟΤΗΤΑ' : app.status}
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
                
                <p class="mt-6 text-center text-xs text-outline">
                    Σημείωση: Τα ραντεβού εμφανίζονται με σειρά ημερομηνίας δημιουργίας (πιο πρόσφατα πρώτα).
                </p>
            </div>
        )}
    </main>
</Layout>
