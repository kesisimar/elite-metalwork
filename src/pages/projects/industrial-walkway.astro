---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Βιομηχανικοί Διάδρομοι" active="projects">
  <main class="pt-32 pb-24 max-w-[1440px] mx-auto px-6 md:px-12">
    <a href="/projects" class="text-xs font-black uppercase tracking-widest text-primary flex items-center mb-12 hover:translate-x-[-4px] transition-transform">
      <span class="material-symbols-outlined mr-2">arrow_back</span> Επιστροφή στα Έργα
    </a>
    <header class="mb-16">
      <h1 class="text-4xl md:text-7xl font-black italic text-white uppercase mb-8 leading-none">ΒΙΟΜΗΧΑΝΙΚΟΙ <br/> <span class="text-primary">ΔΙΑΔΡΟΜΟΙ</span></h1>
      <p class="text-xl text-text-muted max-w-2xl leading-relaxed">Μεταλλική γέφυρα βιομηχανικών εγκαταστάσεων για ασφαλή πρόσβαση προσωπικού.</p>
    </header>
    <div class="aspect-video overflow-hidden border border-border/50 mb-16">
      <img src="https://images.unsplash.com/photo-1513828583688-c52646db42da?q=80&w=2070&auto=format&fit=crop" alt="Λεπτομέρεια Έργου" class="w-full h-full object-cover" />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-text-muted">
      <div>
        <h3 class="text-white font-black uppercase tracking-widest text-xs mb-4">ΠΕΛΑΤΗΣ</h3>
        <p>Logistics Center X</p>
      </div>
      <div>
        <h3 class="text-white font-black uppercase tracking-widest text-xs mb-4">ΚΑΤΗΓΟΡΙΑ</h3>
        <p>Μηχανική Ασφαλείας</p>
      </div>
      <div>
        <h3 class="text-white font-black uppercase tracking-widest text-xs mb-4">ΤΟΠΟΘΕΣΙΑ</h3>
        <p>Inofyta, Viotia</p>
      </div>
    </div>
  </main>
</Layout>
