---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Custom Fabrications" active="projects">
  <main class="pt-32 pb-24 max-w-[1440px] mx-auto px-6 md:px-12">
    <a href="/projects" class="text-xs font-black uppercase tracking-widest text-primary flex items-center mb-12 hover:translate-x-[-4px] transition-transform">
      <span class="material-symbols-outlined mr-2">arrow_back</span> Back to Projects
    </a>
    <header class="mb-16">
      <h1 class="text-4xl md:text-7xl font-black italic text-white uppercase mb-8 leading-none">Custom <br/> <span class="text-primary">Fabrications</span></h1>
      <p class="text-xl text-text-muted max-w-2xl leading-relaxed">Ειδικές μεταλλικές κατασκευές για την αυτοκινητοβιομηχανία και εξειδικευμένο εξοπλισμό.</p>
    </header>
    <div class="aspect-video overflow-hidden border border-border/50 mb-16">
      <img src="https://images.unsplash.com/photo-1565615833231-e8c91a38a012?q=80&w=2070&auto=format&fit=crop" alt="Project Detail" class="w-full h-full object-cover" />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-text-muted">
      <div>
        <h3 class="text-white font-black uppercase tracking-widest text-xs mb-4">Client</h3>
        <p>AutoTech Solutions</p>
      </div>
      <div>
        <h3 class="text-white font-black uppercase tracking-widest text-xs mb-4">Category</h3>
        <p>Special Projects</p>
      </div>
      <div>
        <h3 class="text-white font-black uppercase tracking-widest text-xs mb-4">Location</h3>
        <p>Thessaloniki, Greece</p>
      </div>
    </div>
  </main>
</Layout>
