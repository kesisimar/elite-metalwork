---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Κλείσε Ραντεβού">
    <main class="pt-32 pb-20 px-4 md:px-8 max-w-7xl mx-auto">
        <div class="mb-12 text-center md:text-left">
            <h1 class="text-4xl font-bold text-primary mb-4">Κλείστε το Ραντεβού σας</h1>
            <p class="text-on-surface-variant">Επιλέξτε ημερομηνία και ώρα.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Calendar Section -->
            <div class="bg-surface-container-low p-6 rounded-2xl shadow-sm border border-outline-variant/10">
                <div class="flex justify-between items-center mb-6">
                    <h2 id="monthDisplay" class="text-xl font-bold"></h2>
                    <div class="flex gap-2">
                        <button id="prevMonth" class="p-2 bg-gray-100 rounded-full hover:bg-gray-200">
                            <span class="material-symbols-outlined">chevron_left</span>
                        </button>
                        <button id="nextMonth" class="p-2 bg-gray-100 rounded-full hover:bg-gray-200">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </button>
                    </div>
                </div>

                <div id="calendarGrid" class="grid grid-cols-7 gap-1 text-center">
                    <!-- Days header -->
                    <div class="font-bold py-2">Δευ</div>
                    <div class="font-bold py-2">Τρι</div>
                    <div class="font-bold py-2">Τετ</div>
                    <div class="font-bold py-2">Πεμ</div>
                    <div class="font-bold py-2">Παρ</div>
                    <div class="font-bold py-2">Σαβ</div>
                    <div class="font-bold py-2">Κυρ</div>
                    <!-- Days will be injected here -->
                </div>
            </div>

            <!-- Slots & Form Section -->
            <div class="space-y-6">
                <div id="slotsSection" class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                    <h3 class="font-bold mb-4">Διαθέσιμες Ώρες</h3>
                    <div id="slotsGrid" class="grid grid-cols-3 gap-2">
                        <p class="col-span-3 text-gray-500 text-sm">Επιλέξτε ημερομηνία...</p>
                    </div>
                </div>

                <form id="bookingForm" class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 space-y-4">
                    <input type="text" name="name" placeholder="Ονοματεπώνυμο" required class="w-full p-4 bg-gray-50 rounded-xl border-none focus:ring-2 focus:ring-primary" />
                    <input type="tel" name="phone" placeholder="Τηλέφωνο" required class="w-full p-4 bg-gray-50 rounded-xl border-none focus:ring-2 focus:ring-primary" />
                    <select name="purpose" class="w-full p-4 bg-gray-50 rounded-xl border-none focus:ring-2 focus:ring-primary">
                        <option>Απώλεια Βάρους</option>
                        <option>Αθλητική Διατροφή</option>
                        <option>Κλινική Διατροφή</option>
                    </select>
                    <button type="submit" class="w-full bg-primary text-white py-4 rounded-xl font-bold hover:opacity-90 transition-opacity">
                        Επιβεβαίωση Ραντεβού
                    </button>
                </form>
            </div>
        </div>
    </main>
</Layout>

<script is:inline>
    // Constants
    const GREEK_MONTHS = ["Ιανουάριος", "Φεβρουάριος", "Μάρτιος", "Απρίλιος", "Μάιος", "Ιούνιος", "Ιούλιος", "Αύγουστος", "Σεπτέμβριος", "Οκτώβριος", "Νοέμβριος", "Δεκέμβριος"];
    const AVAILABLE_HOURS = ["09:00", "10:30", "12:00", "14:00", "16:30", "18:00"];

    // State
    let viewDate = new Date();
    let selectedDate = null;
    let selectedTime = null;

    // DOM
    const monthDisplay = document.getElementById('monthDisplay');
    const calendarGrid = document.getElementById('calendarGrid');
    const prevBtn = document.getElementById('prevMonth');
    const nextBtn = document.getElementById('nextMonth');
    const slotsGrid = document.getElementById('slotsGrid');
    const bookingForm = document.getElementById('bookingForm');

    function render() {
        const year = viewDate.getFullYear();
        const month = viewDate.getMonth();
        
        // Month Text
        monthDisplay.innerText = `${GREEK_MONTHS[month]} ${year}`;

        // Clear previous days (keep headers)
        const headers = Array.from(calendarGrid.children).slice(0, 7);
        calendarGrid.innerHTML = '';
        headers.forEach(h => calendarGrid.appendChild(h));

        // Logic
        const firstDay = new Date(year, month, 1).getDay();
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const offset = firstDay === 0 ? 6 : firstDay - 1;

        // Padding
        for (let i = 0; i < offset; i++) {
            const div = document.createElement('div');
            div.className = "py-4";
            calendarGrid.appendChild(div);
        }

        const today = new Date();
        today.setHours(0,0,0,0);

        for (let day = 1; day <= daysInMonth; day++) {
            const dateObj = new Date(year, month, day);
            const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
            const isPast = dateObj < today;

            const btn = document.createElement('button');
            btn.type = 'button';
            btn.innerText = day;
            btn.className = `py-3 rounded-lg font-bold transition-colors ${
                selectedDate === dateStr ? 'bg-primary text-white' : 'hover:bg-gray-100'
            }`;

            if (isPast) {
                btn.disabled = true;
                btn.className = "py-3 text-gray-300 cursor-not-allowed";
            } else {
                btn.onclick = () => {
                    selectedDate = dateStr;
                    selectedTime = null;
                    render();
                    fetchSlots(dateStr);
                };
            }
            calendarGrid.appendChild(btn);
        }
    }

    async function fetchSlots(date) {
        slotsGrid.innerHTML = '<p class="col-span-3 text-primary animate-pulse">Φόρτωση...</p>';
        try {
            const res = await fetch(`/get-availability?date=${date}`);
            const data = await res.json();
            const booked = data.bookedTimes || [];
            
            slotsGrid.innerHTML = '';
            AVAILABLE_HOURS.forEach(time => {
                const isBooked = booked.includes(time);
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.innerText = time;
                btn.className = `p-3 rounded-lg border-2 font-bold transition-all ${
                    selectedTime === time ? 'bg-primary border-primary text-white' : 'border-gray-100 hover:border-primary'
                } ${isBooked ? 'opacity-30 cursor-not-allowed' : ''}`;
                
                if (!isBooked) {
                    btn.onclick = () => {
                        selectedTime = time;
                        fetchSlots(date); // Re-render slots
                    };
                } else {
                    btn.disabled = true;
                }
                slotsGrid.appendChild(btn);
            });
        } catch (e) {
            slotsGrid.innerHTML = '<p class="col-span-3 text-red-500">Σφάλμα σύνδεσης.</p>';
        }
    }

    prevBtn.onclick = () => {
        viewDate.setMonth(viewDate.getMonth() - 1);
        render();
    };

    nextBtn.onclick = () => {
        viewDate.setMonth(viewDate.getMonth() + 1);
        render();
    };

    bookingForm.onsubmit = async (e) => {
        e.preventDefault();
        if (!selectedDate || !selectedTime) return alert('Επιλέξτε ημερομηνία και ώρα!');

        const fd = new FormData(bookingForm);
        const submitBtn = bookingForm.querySelector('button');
        submitBtn.disabled = true;
        submitBtn.innerText = 'Υποβολή...';

        try {
            const res = await fetch('/submit-booking', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name: fd.get('name'),
                    phone: fd.get('phone'),
                    purpose: fd.get('purpose'),
                    date: selectedDate,
                    time: selectedTime
                })
            });
            const data = await res.json();
            if (data.success) {
                alert('Επιτυχία! Θα σας καλέσουμε για επιβεβαίωση.');
                window.location.reload();
            } else {
                alert('Σφάλμα: ' + data.error);
                submitBtn.disabled = false;
                submitBtn.innerText = 'Επιβεβαίωση Ραντεβού';
            }
        } catch (e) {
            alert('Σφάλμα σύνδεσης.');
            submitBtn.disabled = false;
            submitBtn.innerText = 'Επιβεβαίωση Ραντεβού';
        }
    };

    // Initial render
    render();
</script>
